rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.enabled == true;
    }

    function changesOnlyCurrentTurn() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['state', 'updatedAt'])
        && request.resource.data.state.diff(resource.data.state).affectedKeys()
          .hasOnly(['activeMeetingStudent'])
        && request.resource.data.state.activeMeetingStudent is string;
    }

    match /schedules/{scheduleId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || changesOnlyCurrentTurn();
    }

    match /admins/{adminId} {
      allow read: if signedIn() && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
